# ─── Database ────────────────────────────────────────────────────────────────
# Neon.tech (production) or local postgres
DATABASE_URL=postgresql://voxai:voxai_dev@localhost:5432/voxai

# ─── Redis ───────────────────────────────────────────────────────────────────
# Upstash (production) or local redis
REDIS_URL=redis://localhost:6379

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend — for magic link emails, get at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=VOX AI <noreply@yourdomain.com>

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=voxai-audio-files

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Create products + prices at dashboard.stripe.com
STRIPE_BASIC_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# ─── Python Worker ───────────────────────────────────────────────────────────
# URL the Node BullMQ worker uses to call the Python FastAPI service
PYTHON_WORKER_URL=http://localhost:8001

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional: Whisper model size ────────────────────────────────────────────
# Options: tiny.en, base.en, small.en, medium.en, large
# Larger = more accurate but slower. base.en is a good default.
WHISPER_MODEL=base.en
